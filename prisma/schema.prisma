// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement())
  cpf String @unique
  name String
  birthDate DateTime
  phone String
  email String @unique
  password String
  type String
  active Boolean
  sessions Session[]
  usersAddresses UsersAddresses[]

  @@map("users")
}

model Address {
  id Int @id @default(autoincrement())
  street String
  number Int
  district String
  city String
  state String
  usersAddresses UsersAddresses[]

  @@map("address")
}

model UsersAddresses{
  id Int @id @default(autoincrement())
  userId Int
  addressId Int
  user User @relation(fields: userId, references: [id])
  address Address @relation(fields: addressId, references: [id])

  @@map("usersAddresses")
}

model Session{
  id Int @id @default(autoincrement())
  dateAccess DateTime
  userId Int
  user User @relation(fields: userId, references: [id])

  @@map("session")
}